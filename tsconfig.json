{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noImplicitAny": true,
    "strict": true,
    "strictNullChecks": true
  },
  "exclude": [
    "__wxt_tmp",
    "__wxt_preact_tmp",
    "dist",
    "env",
    "node_modules"
  ]
}
